# CoffeeInsight AI - Frontend Environment Variables
# These are exposed to the client-side code and should not contain secrets

# Application Password (for SecurityGate)
VITE_APP_PASSWORD=1234

# Backend API Configuration
VITE_API_BASE_URL=http://localhost:3000/api/v1

# Feature Flags
VITE_ENABLE_DEMO_MODE=false
VITE_ENABLE_ANALYTICS=true

# Application Settings
VITE_APP_NAME=CoffeeInsight AI
VITE_APP_VERSION=2.0.0-qwen-ai
