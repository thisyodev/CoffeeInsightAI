# CoffeeInsight AI - Frontend Environment Variables Example
# Copy this file to .env and update values as needed

# Application Password (for SecurityGate/Login Page)
# Change this to a secure password in production
VITE_APP_PASSWORD=1234

# Backend API Configuration
# Update this if backend is running on a different host/port
VITE_API_BASE_URL=http://localhost:3000/api/v1

# Feature Flags
# Enable demo mode to bypass authentication
VITE_ENABLE_DEMO_MODE=false

# Enable analytics tracking
VITE_ENABLE_ANALYTICS=true

# Application Settings
VITE_APP_NAME=CoffeeInsight AI
VITE_APP_VERSION=2.0.0-qwen-ai
